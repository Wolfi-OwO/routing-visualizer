# ── Frontend configuration (Vite — only VITE_* vars are exposed to the app) ────
# Read in src/config/index.ts. Copy to .env.local and adjust as needed.
# Fields mirror the OpenContainer (OCI) image annotations (org.opencontainers.image.*).

VITE_APP_NAME=NetViz
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Enterprise network visualizer & packet simulator
VITE_APP_COMPANY=Woofi-Developments
VITE_APP_AUTHORS=Woofi-Developments
VITE_APP_URL=https://github.com/Wolfi-OwO/routing-visualizer
VITE_APP_LICENSES=MIT

# Usually filled by the release pipeline from git — leave blank locally:
VITE_APP_REVISION=
VITE_APP_CREATED=

VITE_REPO_LABEL=Wolfi-OwO/routing-visualizer
VITE_REPO_URL=https://github.com/Wolfi-OwO/routing-visualizer
